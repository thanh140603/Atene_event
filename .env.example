# ---- Database ----
POSTGRES_USER=atene
POSTGRES_PASSWORD=atene_secret
POSTGRES_DB=atene_event

# Backend uses these to connect to the db service
DB_HOST=db
DB_PORT=5432

# ---- Backend ----
BACKEND_PORT=3000
NODE_ENV=production

# ---- Host port mapping ----
# Frontend served here:
FRONTEND_HOST_PORT=8080
# Backend API exposed here (mostly for debugging; frontend talks to it via the internal network):
BACKEND_HOST_PORT=3001
# Postgres exposed here (for a local DB client):
DB_HOST_PORT=5432

# ---- Media / Videos ----
# Public base URL of the cloud bucket folder that holds brand videos.
# Example (Cloudflare R2 public bucket): https://pub-xxxxxxxx.r2.dev/vids
# Leave unset to serve from /vids on the local filesystem (dev only).
VITE_VIDEO_BASE_URL=

# ---- Google Sign-In (livestream booking) ----
# Google OAuth 2.0 Web client ID. Create one at:
#   https://console.cloud.google.com/apis/credentials
# Add your site origin(s) to "Authorized JavaScript origins"
#   (e.g. http://localhost:8080 and your production URL).
# Set BOTH to the same client ID: the frontend (button) and backend (token verify).
VITE_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_ID=

# ---- Email (booking confirmations) ----
# Gmail SMTP. Requirements on the sending Google account:
#   1. Enable 2-Step Verification.
#   2. Create an App Password: https://myaccount.google.com/apppasswords
#      (pick "Mail" / "Other") — this 16-char code is SMTP_PASS (remove spaces).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-account@gmail.com
SMTP_PASS=your-16-char-app-password
# "From" address shown to recipients (usually same as SMTP_USER for Gmail).
MAIL_FROM=Atene Event <your-account@gmail.com>
# Optional: where booker replies should go. Leave blank to reply to MAIL_FROM.
MAIL_REPLY_TO=
# Optional: public https URL of the banner image at the top of the email.
MAIL_BANNER_URL=
